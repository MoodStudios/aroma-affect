{
  "schemaVersion": 1,
  "id": "aromaaffect",
  "version": "${version}",
  "name": "Aroma Affect",
  "description": "A Minecraft mod that brings the sense of smell to your gameplay through OVR scent hardware integration.",
  "authors": [
    "Mood Studios",
    "OVR Technology"
  ],
  "contact": {
    "homepage": "https://ovrtechnology.com/",
    "sources": "https://github.com/MoodStudios/aroma-affect"
  },
  "license": "Proprietary",
  "icon": "assets/aromaaffect/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.ovrtechnology.fabric.ExampleModFabric"
    ],
    "client": [
      "com.ovrtechnology.fabric.client.ExampleModFabricClient"
    ]
  },
  "accessWidener": "aromaaffect.accesswidener",
  "mixins": [
    "aromaaffect.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "architectury": ">=19.0.0",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
